<style>
    @reference "../styles/global.css";
    .board {
        background-color: rgba(61, 81, 63, 0.9);
        margin: 20px;
        @apply outline outline-green-400 rounded-tl-2xl rounded-br-2xl flex flex-col justify-center gap-5 py-5 px-5;
    }
    .board .board_headline {
        @apply text-fluid-h1;
    }
    .board .board_body {
        @apply flex items-center justify-center min-h-40 gap-5;
    }
    .board .board_item {
        @apply flex items-center justify-center h-30 bg-amber-100 py-5 px-5 text-fluid-h3 rounded-2xl shadow-lg outline outline-blue-400;
    }
</style>
<section class="board">
    <div class="board_headline">Bulletin Board</div>
    <div class="board_body">
        <div class="board_item">Hello, This is a board note</div>
    </div>
</section>
